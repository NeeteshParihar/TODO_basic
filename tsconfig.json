{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",             // Better for modern Node.js ESM
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,                   // Keeps your code quality high
    "esModuleInterop": true,          // Ensures compatibility with CommonJS libs
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,                // Helps with debugging in VS Code
    "removeComments": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}